# API Configuration
API_URL=https://api.datamuse.com
API_TIMEOUT=5000
VITE_API_URL=https://api.datamuse.com
VITE_API_TIMEOUT=5000

# Application Settings
APP_TITLE=Word Game Challenge
MAX_ATTEMPTS=5
DEFAULT_WORD_LENGTH=5

# Development Settings
DEV_SERVER_PORT=8080
VITE_ENABLE_DEBUG_LOGS=false

# Production Error Reporting
# Optional endpoint to receive client-side runtime errors (POST JSON).
VITE_CLIENT_ERROR_ENDPOINT=
# Number of client errors to keep in localStorage as fallback.
VITE_MAX_STORED_CLIENT_ERRORS=50
# LocalStorage key for captured client errors.
VITE_CLIENT_ERROR_STORAGE_KEY=word_game_client_errors
